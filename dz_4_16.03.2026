# 1. Узнаем, сколько машин проехало
n = int(input())

# 2. Заводим переменные-помощники
max_speed = 0  # Самая большая скорость (начнем с нуля)
min_speed = 301  # Самая маленькая скорость (начнем с максимума + 1)
slow_cars = 0  # Счетчик тех, кто едет 30 км/ч и медленнее

# 3. Просим ввести скорость для каждой из N машин
for i in range(n):
    speed = int(input())

    # Если эта скорость больше той, что мы видели раньше — запоминаем её как новую макс.
    if speed > max_speed:
        max_speed = speed

    # Если эта скорость меньше той, что мы видели раньше — запоминаем её как новую мин.
    if speed < min_speed:
        min_speed = speed

    # Если машина едет медленно (30 или меньше) — загибаем палец (прибавляем 1)
    if speed <= 30:
        slow_cars += 1


print(max_speed - min_speed)  # Разница между самой быстрой и самой медленной
print(slow_cars)  # Сколько было медленных машин
